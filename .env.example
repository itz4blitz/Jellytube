HOST=0.0.0.0
PORT=3135
APP_NAME=Jellytube
JELLYFIN_URL=http://localhost:8096
JELLYFIN_PUBLIC_URL=https://jellyfin.example.com
METUBE_URL=http://localhost:8081
COOKIE_NAME=jellytube_session
COOKIE_SECRET=replace-with-a-long-random-secret-at-least-32-chars
HANDOFF_SECRET=replace-with-a-second-long-random-secret-at-least-32-chars
COOKIE_SECURE=false
SESSION_TTL_SECONDS=604800
DATA_FILE=./apps/server/data/store.json
ALLOW_PASSWORD_LOGIN=true
AUTO_APPROVE_VIDEO_REQUESTS=false
DEFAULT_QUALITY=best
ALLOWED_HOSTS=youtube.com,youtu.be,rumble.com,odysee.com
JELLYFIN_BRIDGE_START_PATH=/JellytubeBridge/start
